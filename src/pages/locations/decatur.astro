    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "How quickly can Rittenworx come out for a handyman job in Decatur?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "We typically schedule Decatur estimates within 1–3 business days and complete most jobs within 1–2 weeks of approval. Rittenworx is locally based in Madison, AL, so Decatur is a quick drive for Roy and our crew."
          }
        },
        {
          "@type": "Question",
          name: "What handyman services do you offer in Decatur, AL?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "In Decatur we provide drywall repair and installation, interior and exterior painting, flooring installation (hardwood, LVP, laminate), garage floor coating (epoxy and polyaspartic), finish carpentry, gutter cleaning, and gutter installation. Pricing is by the project, not the hour, with a written estimate up front."
          }
