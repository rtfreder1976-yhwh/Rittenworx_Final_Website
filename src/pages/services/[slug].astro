---
import Layout from "../../layouts/Layout.astro";
import TrustCredentials from "../../components/TrustCredentials.astro";
import InlineQuoteForm from "../../components/InlineQuoteForm.astro";

export function getStaticPaths() {
    const services = [
        {
            id: "drywall-repair",
            name: "Drywall Repair",
            shortDesc: "Professional drywall patching and repair",
        },
        {
            id: "interior-painting",
            name: "Interior Painting",
            shortDesc: "High-quality interior painting services",
        },
        {
            id: "exterior-painting",
            name: "Exterior Painting",
            shortDesc: "Durable exterior house painting",
        },
        {
            id: "gutter-cleaning",
            name: "Gutter Cleaning",
            shortDesc: "Thorough gutter cleaning and maintenance",
        },
        {
            id: "gutter-installation",
            name: "Gutter Installation",
            shortDesc: "Seamless gutter and downspout installation",
        },
        {
            id: "flooring-installation",
            name: "Garage Floor Coating",
            shortDesc: "Professional epoxy and specialty garage floor coatings",
        },
        {
            id: "garage-floor-coating",
            name: "Garage Floor Coating",
            shortDesc: "Professional epoxy and flake garage floor coating systems",
        },
        {
            id: "finish-carpentry",
            name: "Finish Carpentry",
            shortDesc: "Custom trim, crown molding, and woodwork",
        },
    ];
    const cities = [
        "madison-al",
        "huntsville-al",
        "athens-al",
        "decatur-al",
        "harvest-al",
        "owens-cross-roads-al",
        "hampton-cove-al",
        "redstone-arsenal-al"
    ];

    const paths: any[] = [];

    services.forEach((service) => {
        cities.forEach((city) => {
            const cityNameObj: Record<string, {name: string, path: string}> = {
                "madison-al": { name: "Madison", path: "madison" },
                "huntsville-al": { name: "Huntsville", path: "huntsville" },
                "athens-al": { name: "Athens", path: "athens" },
                "decatur-al": { name: "Decatur", path: "decatur" },
                "harvest-al": { name: "Harvest", path: "madison/harvest" },
                "owens-cross-roads-al": { name: "Owens Cross Roads", path: "owens-cross-roads" },
                "hampton-cove-al": { name: "Hampton Cove", path: "huntsville/hampton-cove" },
                "redstone-arsenal-al": { name: "Redstone Arsenal", path: "redstone-arsenal" }
            };
            const cityData = cityNameObj[city];
            paths.push({
                params: { slug: `${service.id}-${city}` },
                props: { service, city: cityData.name, cityPath: cityData.path, fullCity: city },
            });
        });
    });

    return paths;
}

const { service, city, cityPath } = Astro.props;
const { slug } = Astro.params;

const title = `${service.name} in ${city}, AL | Rittenworx`;
const description = `${service.shortDesc} in ${city}, AL. Licensed & insured. Free estimates, fast response. Call (256) 221-0373.`;

// Custom local schema for this specific combination
const localSchema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "LocalBusiness",
            "@id": `https://www.rittenworxhandyman.net/services/${slug}/#business`,
            name: `Rittenworx - ${city}`,
            description: description,
            url: `https://www.rittenworxhandyman.net/services/${slug}`,
            telephone: "(256) 221-0373",
            address: {
                "@type": "PostalAddress",
                addressLocality: city,
                addressRegion: "AL",
            },
            areaServed: [{ "@type": "City", name: city, addressRegion: "AL" }],
        },
        {
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: `How much does ${service.name.toLowerCase()} cost in ${city}, AL?`,
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: `${service.name} pricing in ${city} depends on the scope of work. Rittenworx offers free, no-obligation estimates — call (256) 221-0373 or text a photo of your project for a same-day quote. Most residential jobs are completed within 1–3 days.`,
                    },
                },
                {
                    "@type": "Question",
                    name: `Is Rittenworx licensed and insured for ${service.name.toLowerCase()} in ${city}?`,
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: `Yes. Rittenworx is a licensed, insured handyman service in ${city}, Alabama, carrying $1 million in general liability coverage. We are a family-owned business with 7 years of experience serving North Alabama homeowners.`,
                    },
                },
                {
                    "@type": "Question",
                    name: `How quickly can Rittenworx respond to ${service.name.toLowerCase()} requests in ${city}?`,
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: `We respond to all ${city} service requests within 3 hours. Same-day and emergency service is available for urgent repairs. Call or text (256) 221-0373 to get on our schedule.`,
                    },
                },
                {
                    "@type": "Question",
                    name: `Does Rittenworx offer free estimates for ${service.name.toLowerCase()} near ${city}?`,
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: `Yes — all estimates for ${service.name.toLowerCase()} in ${city} and surrounding North Alabama communities are completely free and carry no obligation. Request yours online or call (256) 221-0373.`,
                    },
                },
            ],
        },
    ],
};
---

<Layout title={title} description={description} schema={localSchema}>
    <!-- Premium Hero Section -->
    <section
        class="relative bg-blue-900 text-white pt-32 pb-24 flex items-center overflow-hidden"
    >
        <div class="absolute inset-0 z-0">
            <img
                src="/hero-handyman.webp"
                alt={`${service.name} Services in ${city}`}
                class="w-full h-full object-cover opacity-20 scale-105 animate-[pulse_10s_ease-in-out_infinite_alternate]"
            />
            <div
                class="absolute inset-0 bg-gradient-to-t from-blue-950 via-blue-900/90 to-blue-900/60"
            >
            </div>
        </div>

        <div class="max-w-7xl mx-auto px-4 relative z-10 w-full">
            <div class="max-w-3xl">
                <nav
                    class="text-blue-200 text-sm mb-6 flex items-center gap-2 font-medium tracking-wide"
                >
                    <a
                        href="/locations"
                        class="hover:text-white transition-colors">Locations</a
                    >
                    <span class="opacity-50">/</span>
                    <a
                        href={`/locations/${cityPath}`}
                        class="hover:text-white transition-colors">{city}</a
                    >
                    <span class="opacity-50">/</span>
                    <span class="text-orange-400">{service.name}</span>
                </nav>

                <div
                    class="inline-block px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-6 text-sm font-medium text-blue-100"
                >
                    <span
                        class="w-2 h-2 inline-block rounded-full bg-orange-400 mr-2 animate-pulse"
                    ></span>
                    Top-Rated {city} Contractor
                </div>

                <h1
                    class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight tracking-tight"
                >
                    {service.name}
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-600"
                        >in {city}, AL</span
                    >
                </h1>

                <p
                    class="text-xl md:text-2xl text-blue-100 mb-10 font-light leading-relaxed"
                >
                    {service.shortDesc} tailored specifically for homes in {
                        city
                    }. Fast, reliable, and backed by a commitment to absolute
                    professionalism.
                </p>

                <div class="flex flex-col sm:flex-row gap-4">
                    <a
                        href="sms:2562210373"
                        class="group bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 text-lg flex items-center justify-center gap-3 shadow-lg shadow-orange-500/30 hover:shadow-orange-500/50 hover:-translate-y-1 border border-orange-400/30"
                    >
                        <svg
                            class="w-6 h-6 group-hover:scale-110 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
                            ></path>
                        </svg>
                        Text A Photo For Instant Quote
                    </a>
                </div>
            </div>
        </div>

        <!-- Decorative shape divider -->
        <div
            class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-10"
        >
            <svg
                class="relative block w-full h-[50px] md:h-[100px]"
                data-name="Layer 1"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 1200 120"
                preserveAspectRatio="none"
            >
                <path
                    d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.06,155.15,112.5,231.2,88.45,264.44,77.83,296.88,67.36,321.39,56.44Z"
                    class="fill-white"></path>
            </svg>
        </div>
    </section>

    <!-- Main Content -->
    <section class="py-20 bg-white">
        <div class="max-w-4xl mx-auto px-4">
            <h2
                class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6 font-display tracking-tight"
            >
                The {service.name} Contractor {city} Homeowners Actually Call Back
            </h2>
            <p class="text-gray-700 text-lg leading-relaxed mb-6">
                Most {city} homeowners have a bad contractor story. The quote that
                ballooned at invoice time. The crew that showed up three days late.
                The work that looked fine — until it didn't. When you need <strong
                    >{service.name.toLowerCase()}</strong
                > done right, the last thing you want is to roll the dice again.
            </p>
            <p class="text-gray-700 text-lg leading-relaxed mb-6">
                Rittenworx has been doing {service.name.toLowerCase()} work in
                North Alabama for 7 years. We carry $1 million in liability
                coverage. We respond within 3 hours. We send a written estimate
                you can hold us to — and the final bill matches it. That's how
                we've built every client relationship we have.
                Whether it's an emergency repair or a project you've been putting
                off, here's what actually happens when you reach out: we answer,
                we schedule, we show up on time. The same crew you talked to is
                the crew that does the work — no handoffs to subcontractors.
                We clean up before we leave. And we walk the job with you before
                we consider it done.
            </p>

            <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 mt-14">
                Why {city} Homeowners Choose Rittenworx First
            </h3>
            <p class="text-gray-700 text-lg leading-relaxed mb-6">
                Unlicensed workers are the single biggest source of costly
                redo work in home repair. If something goes wrong on your property
                and the contractor isn't properly insured, that cost lands on you.
                We're licensed, insured to $1 million, and we can show you the
                certificate before we start.
            </p>
            <p class="text-gray-700 text-lg leading-relaxed mb-10">
                Seven years in Madison County means we know the local construction
                styles, the materials that hold up in North Alabama's climate, and
                the shortcuts that always come back to bite. We use commercial-grade
                materials — not whatever's cheapest at the big-box store — because
                we'd rather do it once than twice.
            </p>

            <div
                class="bg-gradient-to-br from-blue-50 to-white p-8 md:p-10 rounded-3xl border border-blue-100 my-16 shadow-lg shadow-blue-900/5 relative overflow-hidden group hover:border-blue-200 transition-colors"
            >
                <div
                    class="absolute top-0 right-0 w-64 h-64 bg-blue-100 rounded-full blur-[80px] opacity-40 -mr-20 -mt-20 pointer-events-none group-hover:opacity-60 transition-opacity"
                >
                </div>
                <h3 class="text-2xl font-bold text-blue-900 mb-8 relative z-10">
                    What Makes Rittenworx Different in {city}
                </h3>
                <ul class="space-y-6 relative z-10">
                    <li class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-1 shadow-sm border border-green-200"
                        >
                            <svg
                                class="w-5 h-5 text-green-600"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <div>
                            <strong class="text-gray-900 block text-xl mb-1"
                                >We Know {city} Homes</strong
                            >
                            <span class="text-gray-600 leading-relaxed block"
                                >7 years working in Madison County means we've
                                seen the local construction styles, older
                                materials, and the shortcuts that create problems
                                later. We know what holds up in North Alabama's
                                climate — and what doesn't.</span
                            >
                        </div>
                    </li>
                    <li class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-1 shadow-sm border border-green-200"
                        >
                            <svg
                                class="w-5 h-5 text-green-600"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <div>
                            <strong class="text-gray-900 block text-xl mb-1"
                                >3-Hour Response. Real Availability.</strong
                            >
                            <span class="text-gray-600 leading-relaxed block"
                                >You call or text, we respond within 3 hours
                                — not "sometime this week." Most estimates are
                                scheduled same day or next. For emergencies in
                                {city}, we hold daily slots for same-day
                                service.</span
                            >
                        </div>
                    </li>
                    <li class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-1 shadow-sm border border-green-200"
                        >
                            <svg
                                class="w-5 h-5 text-green-600"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <div>
                            <strong class="text-gray-900 block text-xl mb-1"
                                >$1M Coverage on Every Job</strong
                            >
                            <span class="text-gray-600 leading-relaxed block"
                                >Not just a guy with tools. Rittenworx is
                                licensed and carries $1 million in general
                                liability insurance. Your home is covered if
                                anything unexpected happens — and we can show
                                you the certificate before we start.</span
                            >
                        </div>
                    </li>
                    <li class="flex items-start gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0 mt-1 shadow-sm border border-green-200"
                        >
                            <svg
                                class="w-5 h-5 text-green-600"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M5 13l4 4L19 7"></path></svg
                            >
                        </div>
                        <div>
                            <strong class="text-gray-900 block text-xl mb-1"
                                >The Quote Is the Price</strong
                            >
                            <span class="text-gray-600 leading-relaxed block"
                                >You get a written estimate before we start.
                                You approve it. We build it. The final bill
                                matches. We've never handed a {city} homeowner
                                a surprise invoice — and we don't intend to
                                start.</span
                            >
                        </div>
                    </li>
                </ul>
            </div>

            <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 mt-16">
                Here's Exactly What Happens When You Call
            </h3>
            <p class="text-gray-700 text-lg leading-relaxed mb-8">
                No mystery, no runaround. Four steps, every job.
            </p>
            <div class="grid md:grid-cols-2 gap-6 mb-16">
                <div
                    class="bg-white border hover:border-orange-300 border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-all group"
                >
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-10 h-10 rounded-xl bg-orange-100 text-orange-600 font-bold flex items-center justify-center flex-shrink-0 group-hover:bg-orange-500 group-hover:text-white transition-colors"
                        >
                            01
                        </div>
                        <h4 class="font-bold text-gray-900 text-xl">
                            You Reach Out
                        </h4>
                    </div>
                    <p class="text-gray-600 leading-relaxed">
                        Call or text a photo to (256) 221-0373. We respond
                        within 3 hours with a scheduled estimate — usually
                        same day or next morning. No answering machines,
                        no waiting three days for a callback.
                    </p>
                </div>
                <div
                    class="bg-white border hover:border-orange-300 border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-all group"
                >
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-10 h-10 rounded-xl bg-orange-100 text-orange-600 font-bold flex items-center justify-center flex-shrink-0 group-hover:bg-orange-500 group-hover:text-white transition-colors"
                        >
                            02
                        </div>
                        <h4 class="font-bold text-gray-900 text-xl">
                            Free Written Estimate
                        </h4>
                    </div>
                    <p class="text-gray-600 leading-relaxed">
                        We come out, assess the job, and hand you a fixed
                        written quote. No obligation. Nothing starts until
                        you say go. The price on that paper is the price
                        on your invoice.
                    </p>
                </div>
                <div
                    class="bg-white border hover:border-orange-300 border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-all group"
                >
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-10 h-10 rounded-xl bg-orange-100 text-orange-600 font-bold flex items-center justify-center flex-shrink-0 group-hover:bg-orange-500 group-hover:text-white transition-colors"
                        >
                            03
                        </div>
                        <h4 class="font-bold text-gray-900 text-xl">
                            We Do the Work
                        </h4>
                    </div>
                    <p class="text-gray-600 leading-relaxed">
                        Our crew arrives on time with commercial-grade
                        materials. We protect your floors and furniture
                        before we start. No subcontractors — the same
                        people you talked to are the ones doing the job.
                    </p>
                </div>
                <div
                    class="bg-white border hover:border-orange-300 border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-all group"
                >
                    <div class="flex items-center gap-3 mb-4">
                        <div
                            class="w-10 h-10 rounded-xl bg-orange-100 text-orange-600 font-bold flex items-center justify-center flex-shrink-0 group-hover:bg-orange-500 group-hover:text-white transition-colors"
                        >
                            04
                        </div>
                        <h4 class="font-bold text-gray-900 text-xl">
                            You Walk It Before We Leave
                        </h4>
                    </div>
                    <p class="text-gray-600 leading-relaxed">
                        When we're done, we walk the job with you. If
                        anything's not right, we fix it before we pack up
                        — not "next week." We clean up completely. The job
                        isn't done until you say it is.
                    </p>
                </div>
            </div>

            <h3
                class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 mt-16 pb-2 border-b-2 border-gray-100"
            >
                Frequently Asked Questions About {service.name} in {city}
            </h3>
            <div class="space-y-6">
                <div
                    class="bg-white border border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow"
                >
                    <h4
                        class="font-bold text-gray-900 text-xl flex items-start gap-3"
                    >
                        <span class="text-orange-500 font-black mt-1">Q:</span>
                        <span
                            >How much does {service.name.toLowerCase()} cost in {city}?</span
                        >
                    </h4>
                    <p class="text-gray-700 mt-4 ml-8 leading-relaxed text-lg">
                        <strong
                            class="text-blue-900 font-black mr-2 tracking-wide"
                            >A:</strong
                        > Every job is different — scope, materials, and square footage
                        all affect the price. That's why our estimates are free. <a
                            href="sms:2562210373"
                            class="text-orange-600 underline hover:text-orange-700 font-bold transition-colors"
                            >Text us a photo</a
                        > and we'll give you a ballpark in minutes. Need a firm number?
                        We'll come out and hand you a written quote at no charge — no
                        obligation to book.
                    </p>
                </div>

                <div
                    class="bg-white border border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow"
                >
                    <h4
                        class="font-bold text-gray-900 text-xl flex items-start gap-3"
                    >
                        <span class="text-orange-500 font-black mt-1">Q:</span>
                        <span
                            >Is Rittenworx licensed and insured for {service.name.toLowerCase()} in {city}?</span
                        >
                    </h4>
                    <p class="text-gray-700 mt-4 ml-8 leading-relaxed text-lg">
                        <strong
                            class="text-blue-900 font-black mr-2 tracking-wide"
                            >A:</strong
                        > Yes. We're licensed and carry $1 million in general liability
                        insurance. That means your home and your property are covered
                        if anything unexpected happens on the job. We can show you the
                        certificate before we start — just ask.
                    </p>
                </div>

                <div
                    class="bg-white border border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow"
                >
                    <h4
                        class="font-bold text-gray-900 text-xl flex items-start gap-3"
                    >
                        <span class="text-orange-500 font-black mt-1">Q:</span>
                        <span
                            >How quickly can you start my {service.name.toLowerCase()} project?</span
                        >
                    </h4>
                    <p class="text-gray-700 mt-4 ml-8 leading-relaxed text-lg">
                        <strong
                            class="text-blue-900 font-black mr-2 tracking-wide"
                            >A:</strong
                        > Most projects start within 3–5 business days of estimate
                        approval. If it's urgent — storm damage, an active leak, or
                        anything that can't wait — call us directly at
                        <a href="tel:2562210373" class="text-orange-600 underline hover:text-orange-700 font-bold transition-colors"
                            >(256) 221-0373</a>. We hold daily availability for
                        same-day and next-day emergencies in {city}.
                    </p>
                </div>

                <div
                    class="bg-white border border-gray-200 p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow"
                >
                    <h4
                        class="font-bold text-gray-900 text-xl flex items-start gap-3"
                    >
                        <span class="text-orange-500 font-black mt-1">Q:</span>
                        <span
                            >Do I need to buy materials, or does Rittenworx handle that?</span
                        >
                    </h4>
                    <p class="text-gray-700 mt-4 ml-8 leading-relaxed text-lg">
                        <strong
                            class="text-blue-900 font-black mr-2 tracking-wide"
                            >A:</strong
                        > We handle everything. We source, buy, and bring all materials
                        to the job — commercial-grade, not big-box cheapest-option.
                        If you've already picked out specific paint, hardware, or
                        fixtures, just let us know and we'll adjust the labor quote
                        to reflect the lower material cost.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <InlineQuoteForm />

    <TrustCredentials />

    <!-- Final Call to Action -->
