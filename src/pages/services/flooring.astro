---
import Layout from "../../layouts/Layout.astro";
import TrustCredentials from "../../components/TrustCredentials.astro";
import InlineQuoteForm from "../../components/InlineQuoteForm.astro";

const includedServices = [
  {
    title: "Epoxy Flooring Systems",
    items: [
      "Solid color epoxy coatings",
      "Metallic epoxy finishes",
      "Vinyl flake epoxy floors",
      "Quartz epoxy flooring",
      "Commercial shop coatings",
      "Industrial warehouse floors",
      "Basement epoxy finishing",
      "Showroom quality results",
    ],
  },
  {
    title: "Polyaspartic Coatings",
    items: [
      "One-day floor installation",
      "UV-stable topcoats",
      "Superior abrasion resistance",
      "Rapid-cure technology",
      "Cold-weather applicable",
      "Chemical & slip resistance",
      "Extreme durability",
      "Clear & pigmented options",
    ],
  },
  {
    title: "Concrete Preparation",
    items: [
      "Diamond grinding surfaces",
      "Crack & pit repair",
      "Moisture vapor testing",
      "Industrial vacuums (HEPA)",
      "Surface degreasing",
      "Expansion joint filling",
      "Old coating removal",
      "Slab leveling",
    ],
  },
  {
    title: "Specialty Applications",
    items: [
      "Moisture vapor barriers",
      "Decorative broadcast systems",
      "High-traffic protection",
      "Retail & studio flooring",
      "Anti-skid safety textures",
      "Border & logo integration",
      "UV-resistant polyaspartic",
      "Food-grade floor coatings",
    ],
  },
];

const flooringTypes = [
  {
    name: "Standard Epoxy",
    durability: "10-20 years",
    best: "Garages, basements",
    waterproof: "Yes",
    maintenance: "Low - mop and sweep",
  },
  {
    name: "Metallic Epoxy",
    durability: "15-20 years",
    best: "Showrooms, living areas",
    waterproof: "Yes",
    maintenance: "Low - high gloss finish",
  },
  {
    name: "Vinyl Flake",
    durability: "20+ years",
    best: "Garages, shops, patios",
    waterproof: "Yes",
    maintenance: "Very low - textured",
  },
  {
    name: "Polyaspartic",
    durability: "20+ years",
    best: "Commercial, high traffic",
    waterproof: "Yes",
    maintenance: "Minimal maintenance",
  },
  {
    name: "Quartz Epoxy",
    durability: "25+ years",
    best: "Kitchens, heavy utility",
    waterproof: "Yes",
    maintenance: "Extremely durable",
  },
];

const commonProblems = [
  {
    problem: "Peeling or flaking DIY floor kits",
    solution:
      "We grind off the failed DIY coating and apply a professional industrial-grade system that bonds permanently.",
  },
  {
    problem: "Concrete cracks and pitting from salt/wear",
    solution:
      "We patch high-stress cracks and fill pits with polyurea concrete mender before applying the final coating.",
  },
  {
    problem: "Oil and chemical stains on bare concrete",
    solution:
      "We deep-clean using degreasers and diamond grind the slab to remove all contaminants, ensuring a perfect bond.",
  },
  {
    problem: "Moisture vapor or hydrostatic pressure issues",
    solution:
      "We apply specialized moisture vapor barriers to prevent the coating from bubbling or lifting.",
  },
  {
    problem: "Hot tire pick-up peeling standard paint",
    solution:
      "Our high-performance coatings are formulated to withstand the heat from tires without softening or peeling.",
  },
  {
    problem: "Uneven or dusty old concrete slabs",
    solution:
      "Diamond grinding removes the top 'laitance' layer of concrete, eliminating dust and creating a smooth finish.",
  },
];

const processSteps = [
  {
    step: 1,
    title: "Surface Preparation",
    description:
      "We perform industrial-grade diamond grinding to open the pores of the concrete. This creates a profile (CSP 2-3) that allows the coating to sink deep into the slab for a lifetime bond.",
    time: "2-4 hours",
  },
  {
    step: 2,
    title: "Crack Repair & Priming",
    description:
      "We fill all cracks, joints, and pits with high-strength menders. A primary moisture-mitigating primer is then applied to ensure the base coat has zero chance of lifting.",
    time: "1-2 hours",
  },
  {
    step: 3,
    title: "Base Coat & Broadcast",
    description:
      "The industrial base coat is applied, followed immediately by a full broadcast of your chosen color flakes or metallic pigments for a seamless, beautiful finish.",
    time: "2-4 hours",
  },
  {
    step: 4,
    title: "Topcoat Protection",
    description:
      "After the base coat cures, we scrape off excess flake and apply a high-performance polyaspartic clear topcoat that provides UV protection and extreme durability.",
    time: "2-3 hours",
  },
];

const faqs = [
  {
    question: "What is the best coating for a garage floor?",
    answer:
      "A polyaspartic-over-epoxy hybrid system is generally best. It combines the incredible adhesion of epoxy with the UV-stability and rapid-cure times of polyaspartic topcoats.",
  },
  {
    question: "Do I need to move my items out of the garage?",
    answer:
      "Yes, the garage needs to be completely empty. We can help move heavy items to your driveway or a portable storage unit if needed—just let us know during the quote.",
  },
  {
    question: "Can you coat old, damaged concrete?",
    answer:
      "Absolutely. Our diamond grinding process removes aging concrete laitance, and our menders fix cracks and pitting before the coating is ever applied.",
  },
  {
    question: "How much does a garage floor coating cost?",
    answer:
      "Pricing typically depends on the square footage, floor condition, and chosen system. A standard 2-car garage ranges between $2,500 and $4,500 for a multi-layered industrial system.",
  },
  {
    question: "How long does the installation take?",
    answer:
      "Most residential garages take 1-2 days. Day 1 is preparation, patching, and base coat. Day 2 is the clear topcoat application. You can walk on it just 24 hours later.",
  },
  {
    question: "How do I care for my new epoxy floor?",
    answer:
      "Wait at least 24 hours for foot traffic and 72 hours before driving on it. For cleaning, simply use a soft broom or microfiber mop with a mixture of ammonia and water (1/2 cup ammonia to 1 gallon water). Avoid acids like vinegar or citrus cleaners which can dull the gloss over time.",
  },
  {
    question: "What's the difference between Epoxy and Polyaspartic?",
    answer:
      "Epoxy is incredibly durable and bonds strongly to concrete, taking 24-48 hours to cure. Polyaspartic is faster (cures in hours) and is UV-resistant, meaning it won't yellow over time if exposed to sunlight near garage doors. We often use a hybrid system for the best of both worlds.",
  },
  {
    question: "Do you remove existing coatings or tiles?",
    answer:
      "Yes, we use industrial diamond grinding to remove old paint, epoxy, or thin-set from previous tile. This is a critical step to ensure the new coating bonds permanently to the concrete slab.",
  },
  {
    question: "How long should flooring acclimate before installation?",
    answer:
      "Most flooring should acclimate 48-72 hours in the room where it will be installed. This allows the material to adjust to your home's temperature and humidity, preventing expansion issues after installation.",
  },
  {
    question: "Can you match existing flooring for repairs?",
    answer:
      "We do our best to match existing flooring. For common products, we can often find exact matches. For discontinued or older flooring, we'll find the closest match available. Sometimes creative transitions between old and new look best.",
  },
  {
    question: "Do you offer emergency flooring service?",
    answer:
      "Yes! For water damage situations where flooring needs immediate removal to prevent mold, we offer same-day and next-day emergency service. Call us directly for urgent flooring issues.",
  },
  {
    question: "What subfloor preparation is needed?",
    answer:
      "We inspect and prep subfloors as part of every installation. This may include leveling with compound, replacing damaged sections, adding moisture barriers, or installing underlayment. Proper prep is key to flooring that lasts.",
  },
];

const serviceAreas = [
  { city: "Madison", driveTime: "Local", note: "Same-day available" },
  { city: "Huntsville", driveTime: "10-20 min", note: "Same-day available" },
  { city: "Decatur", driveTime: "25-35 min", note: "Serving this area" },
  { city: "Athens", driveTime: "20-30 min", note: "Serving this area" },
  { city: "Harvest", driveTime: "15-25 min", note: "Same-day available" },
  {
    city: "Owens Cross Roads",
    driveTime: "25-35 min",
    note: "Serving this area",
  },
  { city: "Hampton Cove", driveTime: "20-30 min", note: "Serving this area" },
  {
    city: "Redstone Arsenal",
    driveTime: "15-25 min",
    note: "Same-day available",
  },
];
---

<Layout
  title="Garage Floor Coating & Epoxy"
  description="Professional garage floor coating and epoxy in Madison, Huntsville & North Alabama. Durable, high-gloss finishes. Free estimates."
>
  <!-- Premium Hero Section -->
  <section
    class="relative bg-blue-900 text-white pt-32 pb-24 flex items-center overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <img
        src="/images/epoxy-floor.webp"
        alt="Flooring Services"
        class="w-full h-full object-cover opacity-20 scale-105 animate-[pulse_10s_ease-in-out_infinite_alternate]"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-blue-950 via-blue-900/90 to-blue-900/60"
      >
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 relative z-10 w-full">
      <div class="max-w-3xl">
        <nav
          class="text-blue-200 text-sm mb-6 flex items-center gap-2 font-medium tracking-wide"
        >
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="opacity-50">/</span>
          <a href="/services" class="hover:text-white transition-colors"
            >Services</a
          >
          <span class="opacity-50">/</span>
          <span class="text-orange-400">Garage Floor Coating</span>
        </nav>

        <div
          class="inline-block px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/20 mb-6 text-sm font-medium text-blue-100"
        >
          <span
            class="w-2 h-2 inline-block rounded-full bg-orange-400 mr-2 animate-pulse"
          ></span>
          Expert Garage Floor Coatings
        </div>

        <h1
          class="text-5xl md:text-7xl font-extrabold mb-6 leading-tight tracking-tight"
        >
          Garage Floor <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-orange-600"
            >Epoxy Coating</span
          >
        </h1>

        <p
          class="text-xl md:text-2xl text-blue-100 mb-10 font-light leading-relaxed"
        >
          Transform your garage with a premium showroom-quality finish. Durable,
          stain-resistant epoxy coatings installed by experts with meticulous
          attention to every detail.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="sms:2562210373"
            class="group bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 text-lg flex items-center justify-center gap-3 shadow-lg shadow-orange-500/30 hover:shadow-orange-500/50 hover:-translate-y-1 border border-orange-400/30"
          >
            <svg
              class="w-6 h-6 group-hover:scale-110 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
              ></path>
            </svg>
            Text A Photo For Instant Quote
          </a>
        </div>
      </div>
    </div>

    <!-- Decorative shape divider -->
    <div
      class="absolute bottom-0 left-0 w-full overflow-hidden leading-none z-10"
    >
      <svg
        class="relative block w-full h-[50px] md:h-[100px]"
        data-name="Layer 1"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 1200 120"
        preserveAspectRatio="none"
      >
        <path
          d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118.06,155.15,112.5,231.2,88.45,264.44,77.83,296.88,67.36,321.39,56.44Z"
          class="fill-orange-500"></path>
      </svg>
    </div>
  </section>

  <!-- Emergency Banner -->
  <section class="bg-orange-500 text-white py-4">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <svg
            class="w-8 h-8 flex-shrink-0"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <div>
            <p class="font-bold">Emergency Water Damage Service</p>
            <p class="text-sm text-orange-100">
              Flooded floors? We offer same-day removal to prevent mold and
              further damage.
            </p>
          </div>
        </div>
        <a
          href="tel:+12562210373"
          class="bg-white text-orange-500 font-bold py-2 px-6 rounded-lg hover:bg-orange-50 transition-colors whitespace-nowrap"
        >
          Emergency Line
        </a>
      </div>
    </div>
  </section>

  <!-- Comprehensive SEO Introduction -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 prose prose-lg prose-blue">
      <h2
        class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-6 font-display tracking-tight"
      >
        Industrial Grade Garage Floor Coatings
      </h2>
      <p class="text-gray-700 text-lg leading-relaxed mb-6">
        Your garage floor is the foundation of your home's most hard-working space.
        It needs to withstand vehicles, chemicals, temperature fluctuations, and
        heavy traffic. At Rittenworx, we specialize in high-performance epoxy and
        polyaspartic systems that transform dusty concrete into a durable,
        seamless showroom finish.
      </p>
      <p class="text-gray-700 text-lg leading-relaxed mb-6">
        The secret to a lifetime floor is in the preparation. We don't just "paint"
        over your concrete; we use planetary diamond grinders to open the pores of the
        slab, ensuring the coating sinks deep into the concrete. Our process eliminates
        the risk of "hot tire pick-up" and peeling that often ruins DIY store-bought
        kits.
      </p>
      <p class="text-gray-700 text-lg leading-relaxed mb-6">
        Our industrial equipment and meticulous attention to detail ensure a 
        perfectly bonded surface that resists chemicals, salts, and oil stains. 
        We refuse to cut corners, guaranteeing that your new floor is installed 
        strictly according to the manufacturer's stringent specifications to 
        prevent bubbling or delamination.
      </p>

      <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6 mt-14">
        Concrete Repair and Moisture Mitigation
      </h3>
      <p class="text-gray-700 text-lg leading-relaxed mb-6">
        Beyond the aesthetic upgrade, our crews frequently handle complex concrete 
        restoration, including crack repair, pit filling, and moisture vapor 
        remediation. If your slab has high moisture levels, we apply specialized 
        vapor barriers to ensure the epoxy doesn't lift over time—a common issue 
        in the humid North Alabama climate.
      </p>
      <p class="text-gray-700 text-lg leading-relaxed mb-10">
        By exclusively utilizing premium materials and industrial grinding equipment, 
        we ensure that your restored flooring system will beautifully withstand 
        heavy vehicle traffic and environmental challenges for decades to come, 
        bringing you lasting peace of mind and significantly increasing your 
        property's value.
      </p>
    </div>
  </section>

  <!-- What's Included -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">What's Included</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Professional concrete preparation and high-performance coating systems.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        {
          includedServices.map((category) => (
            <div class="bg-gray-50 rounded-lg p-6 border border-gray-100">
              <h3 class="text-xl font-bold text-blue-900 mb-4 flex items-center gap-2">
                <svg
                  class="w-6 h-6 text-orange-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"
                  />
                </svg>
                {category.title}
              </h3>
              <ul class="space-y-2">
                {category.items.map((item) => (
                  <li class="flex items-start gap-2 text-gray-700">
                    <svg
                      class="w-4 h-4 text-green-500 mt-1 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Flooring Comparison Guide -->
  <section class="py-12 bg-blue-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8 text-gray-800">
        Flooring Comparison Guide
      </h2>
      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-lg shadow-sm">
          <thead>
            <tr class="bg-blue-900 text-white">
              <th class="px-4 py-3 text-left font-semibold">Type</th>
              <th class="px-4 py-3 text-left font-semibold">Lifespan</th>
              <th class="px-4 py-3 text-left font-semibold">Best For</th>
              <th class="px-4 py-3 text-left font-semibold">Waterproof</th>
              <th class="px-4 py-3 text-left font-semibold">Maintenance</th>
            </tr>
          </thead>
          <tbody>
            {
              flooringTypes.map((floor, index) => (
                <tr class={index % 2 === 0 ? "bg-gray-50" : "bg-white"}>
                  <td class="px-4 py-3 font-semibold text-blue-900">
                    {floor.name}
                  </td>
                  <td class="px-4 py-3 text-gray-700">{floor.durability}</td>
                  <td class="px-4 py-3 text-gray-700">{floor.best}</td>
                  <td class="px-4 py-3">
                    {floor.waterproof === "Yes" ? (
                      <span class="inline-flex items-center gap-1 text-green-600">
                        <svg
                          class="w-4 h-4"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 13l4 4L19 7"
                          />
                        </svg>
                        Yes
                      </span>
                    ) : floor.waterproof === "Some" ? (
                      <span class="text-yellow-600">Some options</span>
                    ) : (
                      <span class="inline-flex items-center gap-1 text-red-500">
                        <svg
                          class="w-4 h-4"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"
                          />
                        </svg>
                        No
                      </span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-gray-600 text-sm">
                    {floor.maintenance}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
      <p class="text-center text-gray-500 text-sm mt-4">
        Not sure which flooring is right for you? We'll help you choose based on
        your lifestyle, budget, and needs.
      </p>
    </div>
  </section>

  <!-- Common Problems We Solve -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">
          Common Problems We Solve
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Whatever flooring issue you're facing, we have the expertise to fix it
          right.
        </p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {
          commonProblems.map((item) => (
            <div class="bg-white rounded-lg p-6 shadow-sm border border-gray-100">
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg
                    class="w-5 h-5 text-red-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                    />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-800 mb-2">
                    {item.problem}
                  </h3>
                  <p class="text-gray-600 text-sm flex items-start gap-2">
                    <svg
                      class="w-4 h-4 text-green-500 mt-0.5 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {item.solution}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-800 mb-4">
          Our Installation Process
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          A proven process that delivers beautiful, lasting floors every time.
        </p>
      </div>
      <div class="relative">
        <!-- Timeline line -->
        <div
          class="hidden md:block absolute left-1/2 transform -translate-x-1/2 h-full w-1 bg-blue-100"
        >
        </div>

        <div class="space-y-8 md:space-y-12">
          {
            processSteps.map((step, index) => (
              <div
                class={`flex flex-col md:flex-row gap-4 md:gap-8 ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"}`}
              >
                <div
                  class={`flex-1 ${index % 2 === 0 ? "md:text-right" : "md:text-left"}`}
                >
                  <div
                    class={`bg-gray-50 rounded-lg p-6 border border-gray-100 ${index % 2 === 0 ? "md:mr-8" : "md:ml-8"}`}
                  >
                    <div class="flex items-center gap-3 mb-2">
                      <span class="md:hidden w-8 h-8 bg-blue-900 text-white rounded-full flex items-center justify-center font-bold text-sm">
                        {step.step}
                      </span>
                      <h3 class="text-lg font-bold text-gray-800">
                        {step.title}
                      </h3>
                    </div>
                    <p class="text-gray-600 text-sm mb-2">{step.description}</p>
